# Docker ignore file
# Prevents unnecessary files from being copied to Docker images

# Node.js
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn
.pnpm-debug.log*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# TypeScript
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Vuepress build output
.vuepress/dist

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Temporary folders
tmp/
temp/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git
.gitignore

# Docker
Dockerfile*
docker-compose*
.dockerignore

# Documentation
README.md
CHANGELOG.md
LICENSE
*.md

# Test files
test/
tests/
__tests__/
*.test.js
*.spec.js
coverage/

# Build artifacts
build/
dist/
out/

# Config files that shouldn't be in production
webpack.config.js
babel.config.js
jest.config.js
eslint.config.js
prettier.config.js

# Development scripts
scripts/dev/
scripts/test/

# Local development files
.local
local/

# Database files
*.db
*.sqlite
*.sqlite3

# Backup files
*.bak
*.backup

# Lock files (package-lock.json is needed for reproducible builds)
yarn.lock
pnpm-lock.yaml

# Expo specific
.expo/
.expo-shared/
web-build/
dist-build/

# React Native specific
android/
ios/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
eas-build-metadata.json

# Backend specific
backend/logs/
backend/uploads/
backend/temp/
backend/.cache/

# Frontend specific
frontend/.expo/
frontend/web-build/
frontend/dist-build/
