# Sign-in OTP via SMS (Twilio — https://www.twilio.com). Restart Expo after changing these.
# Without these, OTP is not sent (dev shows the code in an alert).
# → Account SID: Twilio Console → Account (top-left) → Account Info → Account SID
EXPO_PUBLIC_TWILIO_ACCOUNT_SID=
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=
# Your Twilio phone number, E.164, e.g. +15551234567
EXPO_PUBLIC_TWILIO_FROM=

# Web OTP: browsers cannot call Twilio (CORS). Run `npm run server` and point the app at your API:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# The Hono server sends SMS via POST /api/otp/send-sign-in using the Twilio vars above (or TWILIO_* server-only names).
# Optional shared secret — set the same value in API env (OTP_PROXY_SECRET) and here (EXPO_PUBLIC_OTP_PROXY_SECRET).
# OTP_PROXY_SECRET=
# EXPO_PUBLIC_OTP_PROXY_SECRET=
# Optional: country code digits for numbers stored without + (default 1). Use 250 for Rwanda, etc.
# EXPO_PUBLIC_DEFAULT_SMS_COUNTRY_CODE=1

# OAuth 2.0 Configuration (Google Sign-In)
# Get from: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# OAuth 2.0 Configuration (Apple Sign-In)
# Get from: https://developer.apple.com/sign-in-with-apple/
EXPO_PUBLIC_APPLE_CLIENT_ID=

# Get your API base URL from the Rork dashboard (https://rork.com)
# Example: https://your-project-id.rork.run
EXPO_PUBLIC_RORK_API_BASE_URL=

# Server-only (map place search on web). Also set in your Rork/hosting env for places.searchSuggestions.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY is read as fallback when GOOGLE_MAPS_API_KEY is unset.
GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Routes API for navigation (optional - app will use OSRM fallback)
# Get from: https://console.cloud.google.com/apis/library/routes-backend
EXPO_PUBLIC_GOOGLE_ROUTES_API_KEY=

# Set to 0 to hide demo taxi markers / counts on the home map (production)
# EXPO_PUBLIC_DEMO_NEARBY_DRIVERS=0
